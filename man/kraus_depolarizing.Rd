## The function is currently defined as
function (p) 
{
    x <- pauli_X()
    y <- pauli_Y()
    z <- pauli_Z()
    k0 <- sqrt(1 - p) * identity_coin()
    k1 <- sqrt(p/3) * x
    k2 <- sqrt(p/3) * y
    k3 <- sqrt(p/3) * z
    kraus_ops <- list(k0, k1, k2, k3)
    return(kraus_ops)
  }
}
