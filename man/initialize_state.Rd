## The function is currently defined as
function (T, init_coin) 
{
    pos <- pos_grid(T)
    state <- matrix(0, nrow = 2, ncol = length(pos))
    c0 <- init_coin_state(init_coin)
    mid <- which(pos == 0)
    state[, mid] <- c0
    return(state)
  }
}
